#!/bin/bash
# /usr/bin/jdw-install - Gestore Pacchetti Ibrido (Locale/Online) per JDWorld OS
INPUT=$1

# Indirizzo della tua cartella centrale dei pacchetti su GitHub
# (Usa l'URL '://githubusercontent.com' per scaricare i file binari puliti)
# GIT_REPO_URL="https://githubusercontent.com/IL_TUO_USERNAME/IL_TUO_REPO/main"
GIT_REPO_URL="https://github.com/JDWorld/jdwos-repo/releases/download/latest"

if [ -z "$INPUT" ]; then
    echo -e "\e[1;31mErrore:\e[0m Specificare il pacchetto."
    echo "Uso locale: sudo jdw-install nome_pacchetto.jdw"
    echo "Uso online: sudo jdw-install nome-pacchetto"
    exit 1
fi

if [ "$EUID" -ne 0 ]; then
    echo -e "\e[1;31mErrore:\e[0m Questo comando deve essere eseguito con sudo."
    exit 1
fi

# Crea una cartella temporanea sicura in RAM per l'estrazione
TEMP_DIR=$(mktemp -d /tmp/jdwos-installer.XXXXXX)
FILE_TARGET=""

# LOGICA IBRIDA: Controlla se l'input è un file locale o una richiesta online
if [ -f "$INPUT" ]; then
    echo -e "\e[1;34m[JDWorld OS]\e[0m Rilevato pacchetto locale. Elaborazione..."
    FILE_TARGET="$INPUT"
else
    # Se non è un file locale, aggiunge l'estensione e prova a tirarlo giù da GitHub
    PACCHETTO_NAME="${INPUT%.jdw}.jdw"
    echo -e "\e[1;34m[JDWorld OS]\e[0m Pacchetto locale non trovato."
    echo -e "\e[1;36m==> Ricerca online nel cloud di JDWorld:\e[0m $PACCHETTO_NAME..."

    # Scarica il pacchetto forzando il tracking dei redirect di GitHub LFS
    echo -e "Connessione a: $GIT_REPO_URL/$PACCHETTO_NAME"

    # Rimosso -q temporaneamente per vedere cosa succede, aggiunto --auth-no-challenge
    wget --trust-server-names --show-progress "$GIT_REPO_URL/$PACCHETTO_NAME" -O "$TEMP_DIR/$PACCHETTO_NAME"

    # Verifichiamo se il file esiste davvero ed è più grande di 1000 byte (evita i file vuoti o html di errore)
    if [ $? -eq 0 ] && [ -s "$TEMP_DIR/$PACCHETTO_NAME" ] && [ $(stat -c%s "$TEMP_DIR/$PACCHETTO_NAME") -gt 1000 ]; then
        echo -e "\e[1;32m[OK]\e[0m Scaricato con successo da GitHub!"
        FILE_TARGET="$TEMP_DIR/$PACCHETTO_NAME"
    else
        echo -e "\e[1;31m[ERRORE]\e[0m Il server non ha erogato il file reale. Controllo integrità fallito."
        # Stampa l'URL esatto per fare il debug visivo immediato a schermo
        echo "URL tentato: $GIT_REPO_URL/$PACCHETTO_NAME"
        rm -rf "$TEMP_DIR"
        exit 1
    fi

    else
        echo -e "\e[1;31m[ERRORE]\e[0m Impossibile trovare il pacchetto '$INPUT' né in locale né su GitHub."
        rm -rf "$TEMP_DIR"
        exit 1
    fi
fi

# FASE DI ESTRAZIONE E INSTALLAZIONE (Identica e pulita come prima)
echo -e "\e[1;34m[JDWorld OS]\e[0m Estrazione e verifica del pacchetto..."
EXTRACT_DIR=$(mktemp -d /tmp/jdwos-exec.XXXXXX)
tar -xzf "$FILE_TARGET" -C "$EXTRACT_DIR"

if [ -f "$EXTRACT_DIR/install.sh" ]; then
    echo -e "\e[1;32m[INFO]\e[0m Esecuzione dello script di installazione..."
    # Esegue l'install.sh interno passandogli la cartella temporanea
    export SUDO_USER=$SUDO_USER
    bash "$EXTRACT_DIR/install.sh" "$EXTRACT_DIR"
    echo -e "\e[1;32m[OK]\e[0m Installazione completata!"
else
    echo -e "\e[1;31m[ERRORE]\e[0m Pacchetto non conforme (manca install.sh)."
fi

# Registrazione del pacchetto nel database locale per jdw-list
sudo mkdir -p /usr/share/jdwos-pkg/installed
if [ -f "$SRC_DIR/jdw-package.info" ]; then
    sudo cp "$SRC_DIR/jdw-package.info" "/usr/share/jdwos-pkg/installed/${NAME}"
fi

# Pulizia totale istantanea della RAM
rm -rf "$TEMP_DIR"
rm -rf "$EXTRACT_DIR"
