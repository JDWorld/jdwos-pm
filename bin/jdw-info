#!/usr/bin/env bash
# ==============================================================================
# JDWorld OS v6.6.6 - Core Package Manager (jdw-pm)
# File: /usr/bin/jdw-info - Visualizzazione Metadati Locale/Cloud Pages
# ==============================================================================

PACK_NAME="$1"

# Percorsi rigidi locali dell'ecosistema v6.6.6
LOCAL_DB="/usr/share/jdwos-pkg/installed"
TMP_META="/tmp/${PACK_NAME}-cloud.info"

# Unico URL Cloud Centralizzato (Specchio pulito dei metadati senza .info)
URL_PAGES="https://JDWorld.github.io/jdworldos/metadata/${PACK_NAME}"

# Colori di bordo per preservare lo stile Inferno
RED='\033[0;31m'
WHITE='\033[1;37m'
NC='\033[0m'

stampa_scheda() {
    local sorgente="$1"
    local file_info="$2"

    echo -e "${RED}==================================================${NC}"
    echo -e "${WHITE}   SCHEDA TECNICA JDW ($sorgente) - ${PACK_NAME}${NC}"
    echo -e "${RED}==================================================${NC}"

    # Il tuo compilatore corazzato con sed che digerisce gli apostrofi italiani
    cat "$file_info" 2>/dev/null

    echo -e "${RED}==================================================${NC}"
}

# --- FLUSSO DI CONTROLLO ATOMICO ---

# 1. Verifica se il pacchetto è installato localmente
if [ -f "${LOCAL_DB}/${PACK_NAME}" ]; then
    stampa_scheda "LOCALE" "${LOCAL_DB}/${PACK_NAME}"
    exit 0
fi

# 2. Fallback sul Cloud: Interroga solo lo specchio leggero su GitHub Pages
echo -e "${WHITE}[JDWorld OS] Pacchetto non installato. Controllo sul Cloud...${NC}"

# Scarica al volo i pochissimi KB di metadati
wget -q -O "$TMP_META" "$URL_PAGES" 2>/dev/null

# Controllo di integrità: se il file esiste ed è popolato, lo mostra
if [ -s "$TMP_META" ]; then
    stampa_scheda "CLOUD" "$TMP_META"
else
    echo -e "${RED}[ERRORE] Pacchetto sconosciuto o metadati non raggiungibili sul Cloud Pages.${NC}"
fi

# Piallatura del file temporaneo in RAM
rm -f "$TMP_META"
